{
  "name": "downloader",
  "version": "1.0.0",
  "description": "High-performance video downloader GUI for yt-dlp, ffmpeg, and aria2c",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "setup": "node src/scripts/check-tools.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [
    "downloader",
    "yt-dlp",
    "video",
    "electron"
  ],
  "author": "Antigravity",
  "license": "MIT",
  "build": {
    "appId": "com.downloader.pro",
    "productName": "Downloader",
    "directories": {
      "output": "dist",
      "buildResources": "src/assets"
    },
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/assets/icon.png",
      "category": "public.app-category.video"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "files": [
      "src/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "qwerty-ll",
        "repo": "downloader"
      }
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.downloader.pro",
    "productName": "Downloader",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
